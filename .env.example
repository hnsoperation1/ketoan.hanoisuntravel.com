# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — dùng gpt-4o đọc CCCD/thẻ HDV (khớp pattern hns-crm)
OPENAI_API_KEY=

# Telegram — tạo bot qua @BotFather để lấy token
TELEGRAM_BOT_TOKEN=
# Tự đặt 1 chuỗi bí mật bất kỳ, dùng khi gọi setWebhook (secret_token) để xác thực request đến từ Telegram thật
TELEGRAM_WEBHOOK_SECRET=

# URL app khi deploy (dùng để bot trả link dashboard) — vd https://ketoan.hanoisuntravel.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
